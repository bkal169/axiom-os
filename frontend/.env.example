# Axiom OS — Environment Variables
# Copy this file to .env and fill in your values.
# The dev server must be restarted after changes.

# === Supabase (Required for cloud data sync) ===
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# === Optional: Override default API keys ===
# These can also be set in Settings > API Keys within the app.
# App-level settings (localStorage) take priority over env vars.
#
# VITE_ANTHROPIC_KEY=sk-ant-...
# VITE_OPENAI_KEY=sk-...
# VITE_GROQ_KEY=gsk_...
# VITE_TOGETHER_KEY=tog_...
